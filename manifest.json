
{
  "manifest_version": 3,
  "name": "YT Channel Skipper",
  "version": "1.0",
  "description": "Auto-skips videos from blocked channels and adds a block button to the 3-dots menu.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}